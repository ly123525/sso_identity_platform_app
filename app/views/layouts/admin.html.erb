<!DOCTYPE html>
<html>
  <head>
    <title>SSO Admin</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <%= stylesheet_link_tag 'application', media: 'all', 'data-turbolinks-track': 'reload' %>
  </head>

  <body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
      <div class="container-fluid">
        <%= link_to t('admin.layout.brand'), admin_root_path, class: 'navbar-brand' %>
        <div class="collapse navbar-collapse">
          <ul class="navbar-nav me-auto mb-2 mb-lg-0">
            <li class="nav-item">
              <%= link_to t('admin.nav.dashboard'), admin_root_path, class: 'nav-link' %>
            </li>
            <li class="nav-item">
              <%= link_to t('admin.nav.users'), admin_users_path, class: 'nav-link' %>
            </li>
          </ul>
          <div class="d-flex align-items-center gap-3">
            <%= render 'shared/language_switcher' %>
            <span class="navbar-text"><%= current_user.email %></span>
            <%= button_to t('admin.nav.sign_out'), destroy_user_session_path, method: :delete, class: 'btn btn-outline-light btn-sm' %>
          </div>
        </div>
      </div>
    </nav>

    <main class="container py-4">
      <% if notice.present? %>
        <div class="alert alert-success"><%= notice %></div>
      <% end %>
      <% if alert.present? %>
        <div class="alert alert-danger"><%= alert %></div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>
