<div class="row justify-content-center">
  <div class="col-lg-7">
    <div class="card">
      <div class="card-body text-center py-5">
        <h1 class="h3 mb-3">Access denied</h1>
        <p class="text-muted mb-4">
          Your account is signed in, but it does not have permission to access the admin area.
        </p>
        <%= button_to 'Sign out', destroy_user_session_path, method: :delete, class: 'btn btn-outline-secondary' %>
      </div>
    </div>
  </div>
</div>
