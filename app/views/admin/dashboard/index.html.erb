<div class="d-flex align-items-center justify-content-between mb-4">
  <div>
    <h1 class="h3 mb-1">Dashboard</h1>
    <p class="text-muted mb-0">Manage users and identity platform settings.</p>
  </div>
</div>

<div class="row g-3">
  <div class="col-md-4">
    <div class="card">
      <div class="card-body">
        <div class="text-muted">Total users</div>
        <div class="display-6"><%= @users_count %></div>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card">
      <div class="card-body">
        <div class="text-muted">Admins</div>
        <div class="display-6"><%= @admins_count %></div>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card">
      <div class="card-body">
        <div class="text-muted">Active users</div>
        <div class="display-6"><%= @active_users_count %></div>
      </div>
    </div>
  </div>
</div>

<div class="mt-4">
  <%= link_to 'Manage users', admin_users_path, class: 'btn btn-primary' %>
</div>
