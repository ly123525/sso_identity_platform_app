<div class="d-flex align-items-center justify-content-between mb-4">
  <div>
    <h1 class="h3 mb-1"><%= t('admin.users.password.title') %></h1>
    <p class="text-muted mb-0"><%= t('admin.users.password.subtitle', email: @user.email) %></p>
  </div>
  <%= link_to t('admin.users.actions.back'), admin_users_path, class: 'btn btn-outline-secondary' %>
</div>

<div class="card">
  <div class="card-body">
    <% if @user.errors.any? %>
      <div class="alert alert-danger">
        <div class="fw-semibold mb-2"><%= t('admin.users.password.error_title') %></div>
        <ul class="mb-0">
          <% @user.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with model: @user, url: update_password_admin_user_path(@user), method: :patch, local: true do |form| %>
      <div class="row">
        <div class="col-md-6 mb-3">
          <%= form.label :password, t('admin.users.password.new_password'), class: 'form-label' %>
          <%= form.password_field :password, class: 'form-control', required: true %>
        </div>

        <div class="col-md-6 mb-3">
          <%= form.label :password_confirmation, t('admin.users.password.confirm_password'), class: 'form-label' %>
          <%= form.password_field :password_confirmation, class: 'form-control', required: true %>
        </div>
      </div>

      <%= form.submit t('admin.users.actions.reset_password'), class: 'btn btn-primary' %>
    <% end %>
  </div>
</div>
