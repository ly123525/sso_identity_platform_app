<div class="d-flex align-items-center justify-content-between mb-4">
  <div>
    <h1 class="h3 mb-1">Reset password</h1>
    <p class="text-muted mb-0">Set a new password for <%= @user.email %>.</p>
  </div>
  <%= link_to 'Back to users', admin_users_path, class: 'btn btn-outline-secondary' %>
</div>

<div class="card">
  <div class="card-body">
    <% if @user.errors.any? %>
      <div class="alert alert-danger">
        <div class="fw-semibold mb-2">Could not reset password:</div>
        <ul class="mb-0">
          <% @user.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with model: @user, url: update_password_admin_user_path(@user), method: :patch, local: true do |form| %>
      <div class="row">
        <div class="col-md-6 mb-3">
          <%= form.label :password, 'New password', class: 'form-label' %>
          <%= form.password_field :password, class: 'form-control', required: true %>
        </div>

        <div class="col-md-6 mb-3">
          <%= form.label :password_confirmation, 'Confirm new password', class: 'form-label' %>
          <%= form.password_field :password_confirmation, class: 'form-control', required: true %>
        </div>
      </div>

      <%= form.submit 'Reset password', class: 'btn btn-primary' %>
    <% end %>
  </div>
</div>
