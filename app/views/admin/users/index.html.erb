<div class="d-flex align-items-center justify-content-between mb-4">
  <div>
    <h1 class="h3 mb-1">Users</h1>
    <p class="text-muted mb-0">Create and review platform users.</p>
  </div>
  <%= link_to 'New user', new_admin_user_path, class: 'btn btn-primary' %>
</div>

<div class="card">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead>
        <tr>
          <th>Email</th>
          <th>Name</th>
          <th>Role</th>
          <th>Status</th>
          <th>Created</th>
          <th class="text-end">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @users.each do |user| %>
          <tr>
            <td><%= user.email %></td>
            <td><%= user.name.presence || '-' %></td>
            <td><span class="badge bg-secondary"><%= user.role %></span></td>
            <td><span class="badge bg-<%= user.active? ? 'success' : 'warning' %>"><%= user.status %></span></td>
            <td><%= user.created_at.strftime('%Y-%m-%d %H:%M') %></td>
            <td class="text-end">
              <%= link_to 'Edit', edit_admin_user_path(user), class: 'btn btn-outline-secondary btn-sm' %>
              <%= link_to 'Reset password', edit_password_admin_user_path(user), class: 'btn btn-outline-secondary btn-sm ms-1' %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
